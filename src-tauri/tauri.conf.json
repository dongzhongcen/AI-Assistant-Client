{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Assistant Client",
  "version": "1.0.4",
  "identifier": "com.dzc.aiassistant",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File build-tauri-assets.ps1",
    "frontendDist": "../dist/tauri-web"
  },
  "app": {
    "windows": [
      {
        "title": "AI Assistant Client",
        "width": 1180,
        "height": 760,
        "minWidth": 840,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "publisher": "dongzhongcen",
    "copyright": "Copyright 2026 dongzhongcen",
    "category": "Productivity",
    "shortDescription": "A local-first AI assistant client.",
    "longDescription": "AI Assistant Client is a lightweight desktop AI chat client with local-first data and clean uninstall behavior.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
